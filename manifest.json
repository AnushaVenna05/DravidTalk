{
    "manifest_version": 3,
    "name": "DravidaTalk - Telugu to Malayalam",
    "version": "1.0.0",
    "description": "Learn Malayalam from Telugu easily with DravidaTalk. Experience Kerala through its beautiful language.",
    "action": {
        "default_popup": "index.html"
    },
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://generativelanguage.googleapis.com/*"
    ],
    "background": {
        "service_worker": "src/background.ts",
        "type": "module"
    },
    "content_scripts": [
        {
            "js": [
                "src/content.ts"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "icons": {
        "128": "icon.png"
    }
}